<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- CalendarDatePicker 기본 -->
    <ControlTheme x:Key="{x:Type CalendarDatePicker}" TargetType="CalendarDatePicker">
        <Setter Property="Background" Value="{DynamicResource TextControlBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Height" Value="34" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Template">
            <ControlTemplate>
                <DataValidationErrors>
                    <!-- RootBorder가 전체 박스를 감싸고 포커스 시 이 보더만 변경됨 -->
                    <Border Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid ColumnDefinitions="*,Auto">
                            <!-- 내부 텍스트 입력창 -->
                            <TextBox Name="PART_TextBox"
                                     Grid.Column="0"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     Padding="4 0 2 0"
                                     VerticalContentAlignment="Center"
                                     Foreground="{TemplateBinding Foreground}"
                                     Background="Transparent"
                                     FontSize="{TemplateBinding FontSize}"
                                     SelectionBrush="{DynamicResource TextControlSelectionHighlightColor}"
                                     SelectionForegroundBrush="{DynamicResource TextControlSelectionForegroundBrush}">
                                <TextBox.Styles>
                                    <!-- 포커스 시 TextBox 자체 보더가 방지 -->
                                    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </TextBox.Styles>
                            </TextBox>
                            <!-- 달력 아이콘 버튼 -->
                            <Button Name="PART_Button"
                                    Grid.Column="1"

                                    Padding="0"
                                    Margin="0 0 4 0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Focusable="False">
                                <!-- 라인 아이콘 -->
                                <Path Data="M2,5 H18 V19 H2 Z M2,9 H18 M6,2 V5 M14,2 V5 M9,12 H12 L10,17"
                                      Fill="Transparent"
                                      Stroke="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                      StrokeThickness="1.2"
                                      StrokeJoin="Round"
                                      StrokeLineCap="Round"
                                      Stretch="Uniform"
                                      Width="18" Height="18"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                            <!-- 달력 팝업 -->
                            <Popup Name="PART_Popup" IsLightDismissEnabled="True"
                                   PlacementTarget="{Binding ElementName=RootBorder}"
                                   Placement="Bottom"
                                   VerticalOffset="2">
                                <Border Margin="0,0,0,10" Width="220"
                                        Background="{DynamicResource SecondaryBackground}"
                                        BoxShadow="0 4 12 0 #40000000"
                                        CornerRadius="4"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        BorderThickness="0.5">

                                    <Calendar Name="PART_Calendar"
                                              Width="210" HorizontalAlignment="Center"
                                              Background="Transparent"
                                              Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                              SelectedDate="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedDate, Mode=TwoWay}">
                                        <Calendar.Styles>
                                            <Style Selector="CalendarDayButton">
                                                <Setter Property="MinWidth" Value="28" />
                                                <Setter Property="MinHeight" Value="28" />
                                                <Setter Property="FontSize" Value="11" />
                                                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                            </Style>
                                            <Style Selector="CalendarDayButton:selected /template/ ContentControl#PART_SelectedBackground">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                            </Style>
                                            <Style Selector="CalendarItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Template">
                                                    <ControlTemplate>
                                                        <Grid RowDefinitions="Auto,*" Name="PART_Root" HorizontalAlignment="Center" Margin="0,5">
                                                            <Grid Grid.Row="0" Height="30">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                                                    <Button Name="PART_PreviousButton" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0">
                                                                        <Path Data="M 10,5 L 5,10 L 10,15" Stroke="{DynamicResource SystemControlForegroundBaseHighBrush}" StrokeThickness="2"
                                                                              HorizontalAlignment="Center" />
                                                                    </Button>
                                                                    <Button Name="PART_HeaderButton" FontSize="12" FontWeight="Bold"
                                                                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                                            Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Center" />
                                                                    <Button Name="PART_NextButton" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0">
                                                                        <Path Data="M 5,5 L 10,10 L 5,15" Stroke="{DynamicResource SystemControlForegroundBaseHighBrush}" StrokeThickness="2"
                                                                              HorizontalAlignment="Center" />
                                                                    </Button>
                                                                </StackPanel>
                                                            </Grid>
                                                            <Grid Grid.Row="1" Name="PART_MonthView" IsVisible="True" HorizontalAlignment="Center" ColumnDefinitions="*,*,*,*,*,*,*"
                                                                  RowDefinitions="Auto,*,*,*,*,*,*" />
                                                            <Grid Grid.Row="1" Name="PART_YearView" IsVisible="False" HorizontalAlignment="Center" ColumnDefinitions="*,*,*,*" RowDefinitions="*,*,*" />
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter>
                                            </Style>
                                            <Style Selector="CalendarItem /template/ Grid#PART_MonthView Grid > TextBlock">
                                                <Setter Property="Width" Value="28" />
                                                <Setter Property="TextAlignment" Value="Center" />
                                                <Setter Property="FontSize" Value="10" />
                                                <Setter Property="Margin" Value="0,5" />
                                                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                                <Setter Property="Opacity" Value="0.7" />
                                            </Style>
                                        </Calendar.Styles>
                                    </Calendar>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                </DataValidationErrors>
            </ControlTemplate>
        </Setter>
        <!-- 포커스 시 전체 박스 보더 색상 변경 -->
        <Style Selector="^:focus-within /template/ Border#RootBorder">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </ControlTheme>
    <!-- CalendarDatePicker 기본 End -->
</ResourceDictionary>